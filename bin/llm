#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

readonly LLM_ROOT="${LLM_ROOT:-/storage/llm}"
readonly MODELS_DIR="${LLM_MODELS_DIR:-$LLM_ROOT/models}"
readonly REGISTRY_DIR="${LLM_REGISTRY_DIR:-$LLM_ROOT/registry}"
readonly MODELS_JSON="$REGISTRY_DIR/models.json"
readonly SWAP_CONFIG="$REGISTRY_DIR/llama-swap.yaml"
readonly API_BASE="${LLM_API_BASE:-http://127.0.0.1:11343}"
readonly OPENAI_KEY="${LLM_OPENAI_KEY:-local}"
readonly OLLAMA_MANIFEST_ROOT="${OLLAMA_MANIFEST_ROOT:-/storage/ollama/models/manifests}"
readonly OLLAMA_BLOBS_ROOT="${OLLAMA_BLOBS_ROOT:-/storage/ollama/models/blobs}"
readonly DEFAULT_CTX="${LLM_DEFAULT_CTX:-65536}"
readonly DEFAULT_BATCH="${LLM_DEFAULT_BATCH:-256}"
readonly DEFAULT_UBATCH="${LLM_DEFAULT_UBATCH:-128}"
readonly DEFAULT_FIT_TARGET="512"
JSON_OUTPUT=0

usage() {
  cat <<'EOF'
usage: llm <command> [args]

commands:
  help                         show this help
  doctor                       check tools, storage, auth, and services
  search <query>               search Hugging Face GGUF repos
  info [repo|url|model|path]   show repo, file, or registry details
  pull <repo|url> [options]    download and register a selected GGUF
  cache ls|prune               inspect or prune Hugging Face cache
  ls [--long|--registered|--unregistered|--enabled|--disabled|--missing]
                               list local models and registry state
  adopt [--all|--dry-run]      register moved Ollama models from manifests
  add <path> --id <id> [opts]  register a local GGUF
  set [id] [--ctx n] [--gpu-layers n|default] [--batch n] [--ubatch n] [--mmap|--no-mmap] [--flash-attn on|off|auto] [--fit-target mib|default] [--draft off] [--draft-model path] [--draft-hf repo[:quant]] [--draft-n-max n] [--ttl 10m]
                               update runtime settings
  optimize [id] [--ctx n]      live-score and tune llama.cpp runtime settings
  edit [id]                    edit one registry entry
  enable|disable [id]          toggle serving registry state
  reload                       regenerate llama-swap config
  start|stop|restart [id]      control serving
  clear                        unload and reap local llama-server processes
  ps                           show running upstreams
  served                       list /v1/models from llama-swap
  status                       show service and endpoint state
  logs                         tail llama-swap logs
  test [id]                    send a tiny chat request
  chat [id] <prompt>           send one prompt
  bench [id] [opts] [prompt]   run served chat benchmark with token metrics
  rm <id|path> [--dry-run]     remove a model under /storage/llm

global:
  --json                       machine-readable output where supported

examples:
  llm search "qwen3 coder gguf"
  llm info unsloth/Qwen3-Coder-30B-A3B-Instruct-GGUF
  llm pull unsloth/Qwen3-Coder-30B-A3B-Instruct-GGUF
  llm start

bench opts:
  --prompt-tokens n            synthetic prompt size when prompt is omitted (default: 2048)
  --gen-tokens n               max generated tokens (default: 512)

bench env:
  LLM_BENCH_PROMPT_TOKENS      default synthetic prompt size
  LLM_BENCH_GEN_TOKENS         default generated token limit
EOF
}

die() {
  echo "error: $*" >&2
  exit 1
}

log() {
  [[ "$JSON_OUTPUT" -eq 1 ]] && return
  echo "$*" >&2
}

have() {
  command -v "$1" >/dev/null 2>&1
}

require_cmd() {
  have "$1" || die "$1 not found in PATH"
}

ensure_registry() {
  mkdir -p "$MODELS_DIR" "$REGISTRY_DIR"
  if [[ ! -f "$MODELS_JSON" ]]; then
    printf '{"models":{}}\n' >"$MODELS_JSON"
  fi
  if [[ ! -f "$SWAP_CONFIG" ]]; then
    printf 'models: {}\n' >"$SWAP_CONFIG"
  fi
}

json_arg() {
  jq -Rn --arg value "$1" '$value'
}

clean_hf_json() {
  local output="$1" candidate
  if jq -e . >/dev/null 2>&1 <<<"$output"; then
    printf '%s\n' "$output"
    return 0
  fi
  candidate="$(printf '%s\n' "$output" | awk '/^[[:space:]]*[\{\[]/ { print; exit }')"
  [[ -n "$candidate" ]] || return 1
  jq -e . >/dev/null 2>&1 <<<"$candidate" || return 1
  printf '%s\n' "$candidate"
}

normalize_repo() {
  local value="$1"
  value="${value#https://huggingface.co/}"
  value="${value#http://huggingface.co/}"
  value="${value#huggingface.co/}"
  IFS='/' read -r owner repo rest <<<"$value"
  [[ -n "${owner:-}" && -n "${repo:-}" ]] || die "expected Hugging Face repo or URL"
  printf '%s/%s\n' "$owner" "$repo"
}

gguf_file_from_url() {
  local value="$1"
  [[ "$value" == http://huggingface.co/* || "$value" == https://huggingface.co/* || "$value" == huggingface.co/* ]] || return 0
  [[ "$value" == *.gguf* ]] || return 0
  value="${value%%\?*}"
  printf '%s\n' "${value##*/}"
}

hf_json() {
  local repo="$1" output clean
  if ! output="$(hf models info "$repo" --expand siblings,tags,downloads,likes,gated --format json 2>&1)"; then
    printf '%s\n' "$output" >&2
    if [[ "$repo" == *GGU ]]; then
      printf 'did you mean: %sF\n' "$repo" >&2
    fi
    return 1
  fi
  if ! clean="$(clean_hf_json "$output")"; then
    printf 'error: Hugging Face returned non-JSON output for %s\n' "$repo" >&2
    printf '%s\n' "$output" >&2
    if [[ "$repo" == *GGU ]]; then
      printf 'did you mean: %sF\n' "$repo" >&2
    fi
    return 1
  fi
  printf '%s\n' "$clean"
}

list_remote_ggufs() {
  local repo="$1"
  hf_json "$repo" | jq -r --arg repo "$repo" '
    def size: if (.size? // 0) == 0 then "-" else ((.size / 1024 / 1024 / 1024) | tostring) + " GiB" end;
    .siblings[]?
    | select((.rfilename // "") | endswith(".gguf"))
    | [.rfilename, ((.rfilename | (capture("(?<q>Q[0-9A-Za-z_\\-]+)")? // {}) | .q) // "-"), size, "https://huggingface.co/" + $repo + "/resolve/main/" + (.rfilename | @uri)]
    | @tsv
  ' | while IFS=$'\t' read -r file quant size url; do
    if [[ "$size" == "-" ]] && have curl; then
      local headers linked_size
      headers="$(curl -fsSI "$url" 2>/dev/null | tr -d '\r' || true)"
      linked_size="$(printf '%s\n' "$headers" | awk 'BEGIN{IGNORECASE=1} /^x-linked-size:/ {print $2; exit}')"
      if [[ -n "$linked_size" && "$linked_size" =~ ^[0-9]+$ ]]; then
        size="$(awk -v bytes="$linked_size" 'BEGIN { printf "%.1f GiB", bytes / 1024 / 1024 / 1024 }')"
      fi
    fi
    printf '%s\t%s\t%s\n' "$file" "$quant" "$size"
  done
}

hf_file_url() {
  jq -rn --arg repo "$1" --arg file "$2" '"https://huggingface.co/" + $repo + "/resolve/main/" + ($file | @uri)'
}

download_hf_file() {
  require_cmd curl
  local repo="$1" file="$2" target="$3" url part token
  url="$(hf_file_url "$repo" "$file")"
  part="$target.part"
  if [[ -f "$target" ]]; then
    log "already downloaded: $target"
    return
  fi
  token="${HF_TOKEN:-${HUGGING_FACE_HUB_TOKEN:-}}"
  log "downloading: $file"
  log "target: $target"
  if [[ -n "$token" ]]; then
    curl -fL --retry 5 --retry-all-errors --continue-at - --progress-bar --speed-limit 1024 --speed-time 120 \
      -H "authorization: Bearer $token" -o "$part" "$url"
  else
    curl -fL --retry 5 --retry-all-errors --continue-at - --progress-bar --speed-limit 1024 --speed-time 120 \
      -o "$part" "$url"
  fi
  mv "$part" "$target"
}

registry_entry() {
  jq -e --arg id "$1" '.models[$id]' "$MODELS_JSON"
}

model_path() {
  local id="$1"
  if [[ -f "$id" ]]; then
    realpath -m "$id"
    return
  fi
  jq -er --arg id "$id" '
    if .models[$id] then .models[$id].path
    else
      .models
      | to_entries[]
      | select((.value.aliases // []) | index($id))
      | .value.path
    end
  ' "$MODELS_JSON"
}

model_id_from_alias() {
  local id="$1"
  jq -er --arg id "$id" '
    if .models[$id] then $id
    else
      .models
      | to_entries[]
      | select((.value.aliases // []) | index($id))
      | .key
    end
  ' "$MODELS_JSON"
}

is_embedding_model() {
  local id="$1" path
  path="$(model_path "$id" 2>/dev/null || true)"
  [[ "$id ${path##*/}" =~ [Ee]mbed|[Ee]mbedding|(^|[-_.])[Ee]5($|[-_.])|(^|[-_.])[Bb][Gg][Ee]($|[-_.]) ]]
}

require_chat_model() {
  local id="$1"
  if is_embedding_model "$id"; then
    die "$id is an embedding model; chat/start/test/bench need a generative model"
  fi
}

is_known_bad_model() {
  local id="$1" path
  path="$(model_path "$id" 2>/dev/null || true)"
  [[ "$id ${path##*/}" =~ qwen3[-.]5|qwen3\.5 ]]
}

require_startable_model() {
  local id="$1"
  require_chat_model "$id"
  if is_known_bad_model "$id"; then
    die "$id is a known-incompatible imported Qwen3.5 GGUF; replace it with a corrected GGUF before starting"
  fi
}

select_model_id() {
  require_cmd jq
  require_cmd fzf
  ensure_registry
  local include_missing="${1:-0}" prompt="${2:-model}" mode="${3:-any}" rows selected
  [[ -r /dev/tty ]] || die "model id is required without a controlling terminal"
  rows="$(
    jq -r --argjson defaultCtx "$DEFAULT_CTX" '
      .models
      | to_entries[]
      | [
        .key,
        .value.path,
        (.value.enabled // true | tostring),
        (.value.ctx // $defaultCtx | tostring),
        (if (.value.fitTarget // "") != "" then "auto" elif (.value | has("gpuLayers")) then (.value.gpuLayers | tostring) else "99" end),
        ((.value.aliases // []) | join(","))
      ]
      | @tsv
    ' "$MODELS_JSON" | while IFS=$'\t' read -r id path enabled ctx gpu aliases; do
      [[ -n "$id" ]] || continue
      if [[ ! -f "$path" && "$include_missing" != "1" ]]; then
        continue
      fi
      if [[ "$mode" == "served-chat" && "$enabled" == "false" ]]; then
        continue
      fi
      if [[ "$mode" == "chat" || "$mode" == "served-chat" ]]; then
        if [[ "$id ${path##*/}" =~ [Ee]mbed|[Ee]mbedding|(^|[-_.])[Ee]5($|[-_.])|(^|[-_.])[Bb][Gg][Ee]($|[-_.])|qwen3[-.]5|qwen3\.5 ]]; then
          continue
        fi
      fi
      if [[ "$mode" == "enabled" && "$enabled" == "false" ]]; then
        continue
      fi
      local state="enabled" size="missing"
      [[ "$enabled" == "false" ]] && state="disabled"
      if [[ -f "$path" ]]; then
        size="$(du -h "$path" | awk '{print $1}')"
      fi
      printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$id" "$state" "$size" "$ctx" "$gpu" "${aliases:-"-"}"
    done
  )"
  [[ -n "$rows" ]] || die "no registered models found"
  selected="$(printf '%s\n' "$rows" | column -t -s $'\t' | fzf --header='id state size ctx gpu aliases' --prompt="$prompt> ")"
  [[ -n "$selected" ]] || die "no model selected"
  local id
  id="$(awk '{print $1}' <<<"$selected")"
  log "selected: $id"
  printf '%s\n' "$id"
}

model_id_or_select() {
  local prompt="$1" include_missing="$2" value="${3:-}" mode="${4:-any}"
  if [[ -n "$value" ]]; then
    model_id_from_alias "$value"
  else
    select_model_id "$include_missing" "$prompt" "$mode"
  fi
}

select_loaded_model_id() {
  require_cmd jq
  local prompt="${1:-model}" running_json rows selected id
  running_json="$(api_json /running 2>/dev/null || true)"
  if [[ -z "$running_json" ]] || ! jq -e '.running | length > 0' >/dev/null 2>&1 <<<"$running_json"; then
    die "no model is currently loaded"
  fi
  rows="$(jq -r '.running[] | [.model, (.state // "-"), (.proxy // "-"), (.ttl // "-" | tostring)] | @tsv' <<<"$running_json")"
  if [[ "$(printf '%s\n' "$rows" | wc -l)" -eq 1 ]]; then
    selected="$rows"
  else
    require_cmd fzf
    [[ -r /dev/tty ]] || die "model id is required without a controlling terminal"
    selected="$(printf '%s\n' "$rows" | column -t -s $'\t' | fzf --header='model state proxy ttl' --prompt="$prompt> ")"
  fi
  [[ -n "$selected" ]] || die "no model selected"
  id="$(awk '{print $1}' <<<"$selected")"
  log "selected: $id"
  printf '%s\n' "$id"
}

parse_ttl() {
  local value="${1:-600}"
  case "$value" in
    *s) printf '%s\n' "${value%s}" ;;
    *m) printf '%s\n' "$(( ${value%m} * 60 ))" ;;
    *h) printf '%s\n' "$(( ${value%h} * 3600 ))" ;;
    *) printf '%s\n' "$value" ;;
  esac
}

assert_under_llm_root() {
  local path
  path="$(realpath -m "$1")"
  [[ "$path" == "$LLM_ROOT"/* ]] || die "$path is outside $LLM_ROOT"
  printf '%s\n' "$path"
}

sanitize_model_id() {
  local value="$1"
  value="${value##*/}"
  value="${value%.gguf}"
  value="$(printf '%s\n' "$value" | tr '[:upper:]_' '[:lower:]-' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g')"
  [[ -n "$value" ]] || die "could not derive model id"
  printf '%s\n' "$value"
}

register_model() {
  require_cmd jq
  ensure_registry
  local id="$1" path="$2" aliases_json="$3" ctx="$4" gpu_layers="$5" batch="$6" ubatch="$7" ttl="$8" source="$9"
  local existing_path tmp
  path="$(assert_under_llm_root "$path")"
  [[ -f "$path" ]] || die "$path does not exist"
  existing_path="$(jq -r --arg id "$id" '.models[$id].path // empty' "$MODELS_JSON")"
  if [[ -n "$existing_path" && "$existing_path" != "$path" ]]; then
    die "model id already exists for $existing_path; pass --id to choose another id"
  fi
  tmp="$(mktemp "$REGISTRY_DIR/models.json.tmp.XXXXXX")"
  jq \
    --arg id "$id" \
    --arg path "$path" \
    --argjson aliases "$aliases_json" \
    --argjson ctx "$ctx" \
    --argjson gpuLayers "$gpu_layers" \
    --argjson batch "$batch" \
    --argjson ubatch "$ubatch" \
    --argjson ttl "$ttl" \
    --arg source "$source" \
    --arg updatedAt "$(date -Is)" \
    '.models[$id] = ((.models[$id] // {}) + {path:$path, aliases:$aliases, ctx:$ctx, gpuLayers:$gpuLayers, batch:$batch, ubatch:$ubatch, ttl:$ttl, enabled:true, source:$source, updatedAt:$updatedAt})' \
    "$MODELS_JSON" >"$tmp"
  mv "$tmp" "$MODELS_JSON"
  render_config
}

render_config() {
  require_cmd jq
  ensure_registry
  local tmp backup
  tmp="$(mktemp "$REGISTRY_DIR/llama-swap.yaml.tmp.XXXXXX")"
  backup="$REGISTRY_DIR/llama-swap.yaml.last-good"
  jq -r --argjson defaultCtx "$DEFAULT_CTX" --argjson defaultBatch "$DEFAULT_BATCH" --argjson defaultUbatch "$DEFAULT_UBATCH" --argjson defaultFitTarget "$DEFAULT_FIT_TARGET" '
    def shell_args($args):
      if (($args // []) | length) > 0 then
        " " + (($args // []) | map(@sh) | join(" "))
      else
        ""
      end;
    def env_block($model):
      if (($model.env // {}) | length) > 0 then
        "    env:\n"
        + (($model.env // {}) | to_entries | map("      " + .key + ": " + (.value | @json)) | join("\n"))
        + "\n"
      else
        ""
      end;
    def draft_args($model):
      ($model.draft // {}) as $draft
      | if ($draft | type) != "object" or (($draft | length) == 0) then
          ""
        else
          (if ($draft.model // "") != "" then " --model-draft " + ($draft.model | @sh) else "" end)
          + (if ($draft.hf // "") != "" then " --hf-repo-draft " + ($draft.hf | @sh) else "" end)
          + (if ($draft.nMax // "") != "" then " --spec-draft-n-max " + ($draft.nMax | tostring) else "" end)
          + (if ($draft.nMin // "") != "" then " --spec-draft-n-min " + ($draft.nMin | tostring) else "" end)
          + (if ($draft.ctx // "") != "" then " --spec-draft-ctx-size " + ($draft.ctx | tostring) else "" end)
          + (if ($draft.gpuLayers // "") != "" then " --n-gpu-layers-draft " + ($draft.gpuLayers | tostring) else "" end)
          + (if ($draft.cacheTypeK // "") != "" then " --cache-type-k-draft " + $draft.cacheTypeK else "" end)
          + (if ($draft.cacheTypeV // "") != "" then " --cache-type-v-draft " + $draft.cacheTypeV else "" end)
        end;
    def cmd($model):
      "      llama-server --host 127.0.0.1 --port ${PORT} --model " + ($model.path | @sh)
      + " --ctx-size " + (($model.ctx // $defaultCtx) | tostring)
      + (if (($model.fitTarget // "") != "") then "" elif ($model | has("gpuLayers")) then " --n-gpu-layers " + ($model.gpuLayers | tostring) else " --n-gpu-layers 99" end)
      + " --batch-size " + (($model.batch // $defaultBatch) | tostring)
      + " --ubatch-size " + (($model.ubatch // $defaultUbatch) | tostring)
      + (if $model.mmap == false then " --no-mmap" elif $model.mmap == true then " --mmap" else "" end)
      + (if ($model.flashAttn // "") != "" then " --flash-attn " + $model.flashAttn else "" end)
      + (if ($model.fitTarget // "") != "" then " --fit on --fit-target " + ($defaultFitTarget | tostring) + " --fit-ctx " + (($model.ctx // $defaultCtx) | tostring) else " --fit off" end)
      + (if ($model.cpuMoe // "") != "" then " --n-cpu-moe " + ($model.cpuMoe | tostring) else "" end)
      + (if ($model.cacheTypeK // "") != "" then " --cache-type-k " + $model.cacheTypeK else "" end)
      + (if ($model.cacheTypeV // "") != "" then " --cache-type-v " + $model.cacheTypeV else "" end)
      + (if ($model.threads // "") != "" then " --threads " + ($model.threads | tostring) else "" end)
      + (if ($model.threadsBatch // "") != "" then " --threads-batch " + ($model.threadsBatch | tostring) else "" end)
      + (if ($model.splitMode // "") != "" then " --split-mode " + $model.splitMode else "" end)
      + (if ($model.tensorSplit // "") != "" then " --tensor-split " + $model.tensorSplit else "" end)
      + (if ($model.mainGpu // "") != "" then " --main-gpu " + ($model.mainGpu | tostring) else "" end)
      + (if ($model.noKvOffload // false) == true then " --no-kv-offload" else "" end)
      + (if ($model.mlock // false) == true then " --mlock" else "" end)
      + draft_args($model)
      + shell_args($model.serverArgs);
    "healthCheckTimeout: 500\nlogLevel: info\nlogToStdout: proxy\nstartPort: 12000\nincludeAliasesInList: true\nglobalTTL: 0\nmodels:\n"
    + (
      [.models | to_entries[] | select(.value.enabled != false)] as $entries
      | if ($entries | length) == 0 then
          "  {}\n"
        else
          ($entries | map(
            "  " + (.key | @json) + ":\n"
            + "    cmd: >\n"
            + cmd(.value) + "\n"
            + "    ttl: " + ((.value.ttl // 600) | tostring) + "\n"
            + env_block(.value)
            + (if ((.value.aliases // []) | length) > 0 then
                "    aliases:\n" + ((.value.aliases // []) | map("      - " + (. | @json)) | join("\n")) + "\n"
              else "" end)
          ) | join(""))
        end
    )
  ' "$MODELS_JSON" >"$tmp"
  grep -q '^models:' "$tmp" || die "generated llama-swap config is invalid"
  if [[ -f "$SWAP_CONFIG" ]]; then
    cp "$SWAP_CONFIG" "$backup"
  fi
  mv "$tmp" "$SWAP_CONFIG"
}

reload_swap() {
  render_config
  if have systemctl && systemctl is-active --quiet llama-swap 2>/dev/null; then
    sleep 1
  fi
  echo "registry reloaded: $SWAP_CONFIG"
}

wait_for_served_model() {
  local id="$1" attempts="${2:-20}" served
  for _ in $(seq 1 "$attempts"); do
    served="$(api_json /v1/models 2>/dev/null || true)"
    if [[ -n "$served" ]] && jq -e --arg id "$id" 'any(.data[]?; .id == $id)' >/dev/null 2>&1 <<<"$served"; then
      return 0
    fi
    sleep 1
  done
  return 1
}

cmd_doctor() {
  local failed=0
  for cmd in hf jq fzf curl llama-server llama-swap; do
    if have "$cmd"; then
      echo "ok: $cmd"
    else
      echo "missing: $cmd"
      failed=1
    fi
  done
  for dir in "$LLM_ROOT" "$MODELS_DIR" "$REGISTRY_DIR"; do
    if [[ -d "$dir" ]]; then
      echo "ok: $dir"
    else
      echo "missing: $dir"
      failed=1
    fi
  done
  if hf auth whoami >/dev/null 2>&1; then
    echo "ok: hugging face auth configured"
  else
    echo "note: hugging face auth not configured; public models should still work"
  fi
  if curl -fsS "$API_BASE/health" >/dev/null 2>&1; then
    echo "ok: llama-swap health"
  else
    echo "missing: llama-swap health at $API_BASE/health"
  fi
  return "$failed"
}

cmd_search() {
  require_cmd hf
  local limit=50 no_fzf=0 query=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --limit) limit="$2"; shift 2 ;;
      --no-fzf) no_fzf=1; shift ;;
      *) query+=("$1"); shift ;;
    esac
  done
  [[ "${#query[@]}" -gt 0 ]] || die "usage: llm search <query>"
  local results
  results="$(hf models ls --search "${query[*]} gguf" --sort downloads --limit "$limit" --format json)"
  if [[ "$JSON_OUTPUT" -eq 1 ]]; then
    printf '%s\n' "$results"
    return
  fi
  local table
  table="$(printf '%s\n' "$results" | jq -r '.[] | [.id, (.downloads // 0 | tostring), (.likes // 0 | tostring)] | @tsv')"
  if [[ "$no_fzf" -eq 1 || ! -t 1 || ! -t 0 ]]; then
    printf '%s\n' "$table"
  else
    printf '%s\n' "$table" | fzf --with-nth=1 --header='model downloads likes'
  fi
}

cmd_info() {
  require_cmd jq
  [[ $# -le 1 ]] || die "usage: llm info [repo|url|model|path]"
  ensure_registry
  local value="${1:-}"
  if [[ -z "$value" ]]; then
    value="$(select_model_id 1 "info")"
  fi
  if [[ -f "$value" ]]; then
    local path
    path="$(realpath -m "$value")"
    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
      jq -n --arg path "$path" --arg size "$(stat -c '%s' "$path")" '{path:$path,size:($size|tonumber)}'
    else
      echo "path: $path"
      du -h "$path"
    fi
    return
  fi
  if registry_entry "$value" >/dev/null 2>&1 || model_id_from_alias "$value" >/dev/null 2>&1; then
    local id
    id="$(model_id_from_alias "$value")"
    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
      registry_entry "$id"
    else
      registry_entry "$id" | jq -r --arg id "$id" --argjson defaultCtx "$DEFAULT_CTX" --argjson defaultBatch "$DEFAULT_BATCH" --argjson defaultUbatch "$DEFAULT_UBATCH" --argjson defaultFitTarget "$DEFAULT_FIT_TARGET" '"id: \($id)\npath: \(.path)\nenabled: \(.enabled)\naliases: \((.aliases // []) | join(", "))\nctx: \(.ctx // $defaultCtx)\ngpuLayers: \(if (.fitTarget // "") != "" then "auto" elif has("gpuLayers") then .gpuLayers else 99 end)\nbatch: \(.batch // $defaultBatch)\nubatch: \(.ubatch // $defaultUbatch)\nmmap: \(if has("mmap") then .mmap else "default" end)\nflashAttn: \(.flashAttn // "default")\nfitTarget: \(if (.fitTarget // "") != "" then $defaultFitTarget else "default" end)\ncpuMoe: \(.cpuMoe // "default")\ncacheTypeK: \(.cacheTypeK // "default")\ncacheTypeV: \(.cacheTypeV // "default")\nthreads: \(.threads // "default")\nthreadsBatch: \(.threadsBatch // "default")\nsplitMode: \(.splitMode // "default")\ntensorSplit: \(.tensorSplit // "default")\nmainGpu: \(.mainGpu // "default")\nnoKvOffload: \(.noKvOffload // "default")\nmlock: \(.mlock // "default")\ndraft: \((.draft // "default") | if type == "object" then tojson else tostring end)\nserverArgs: \((.serverArgs // []) | join(" "))\nenv: \((.env // {}) | to_entries | map(.key + "=" + .value) | join(" "))\nttl: \(.ttl // 600)"'
    fi
    return
  fi
  require_cmd hf
  local repo
  repo="$(normalize_repo "$value")"
  if [[ "$JSON_OUTPUT" -eq 1 ]]; then
    hf_json "$repo"
  else
    hf_json "$repo" | jq -r '"repo: \(.id)\ndownloads: \(.downloads // 0)\nlikes: \(.likes // 0)\ngated: \(.gated // false)\n\nGGUF files:"'
    list_remote_ggufs "$repo" | column -t -s $'\t'
  fi
}

cmd_pull() {
  require_cmd hf
  require_cmd jq
  local quant="" local_name="" model_id="" repo input selected direct_file
  local ctx="$DEFAULT_CTX" gpu_layers=99 batch="$DEFAULT_BATCH" ubatch="$DEFAULT_UBATCH" ttl=600 aliases_json="[]" register=1 include_mmproj=0
  [[ $# -ge 1 ]] || die "usage: llm pull <repo|url> [--quant Q4_K_M] [--id id] [--name local-name]"
  input="$1"
  shift
  repo="$(normalize_repo "$input")"
  direct_file="$(gguf_file_from_url "$input")"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --quant) quant="$2"; shift 2 ;;
      --name) local_name="$2"; shift 2 ;;
      --id) model_id="$2"; shift 2 ;;
      --alias) aliases_json="$(jq -cn --argjson old "$aliases_json" --arg alias "$2" '$old + [$alias]')"; shift 2 ;;
      --ctx) ctx="$2"; shift 2 ;;
      --gpu-layers)
        case "$2" in
          default|auto|unset) gpu_layers="default" ;;
          *) gpu_layers="$2" ;;
        esac
        shift 2
        ;;
      --batch) batch="$2"; shift 2 ;;
      --ubatch) ubatch="$2"; shift 2 ;;
      --ttl) ttl="$(parse_ttl "$2")"; shift 2 ;;
      --no-register) register=0; shift ;;
      --include-mmproj) include_mmproj=1; shift ;;
      *) die "unknown pull option: $1" ;;
    esac
  done
  local files
  files="$(list_remote_ggufs "$repo")"
  [[ -n "$files" ]] || die "no GGUF files found for $repo"
  if [[ -n "$direct_file" ]]; then
    selected="$direct_file"
  else
    if [[ "$include_mmproj" -eq 0 ]]; then
      files="$(printf '%s\n' "$files" | awk -F '\t' '$1 !~ /^mmproj-/')"
    fi
    if [[ -n "$quant" ]]; then
      files="$(printf '%s\n' "$files" | awk -F '\t' -v q="$quant" 'tolower($0) ~ tolower(q)')"
    fi
    [[ -n "$files" ]] || die "no matching GGUF files found"
    if [[ "$(printf '%s\n' "$files" | wc -l)" -eq 1 || ! -t 0 ]]; then
      selected="$(printf '%s\n' "$files" | head -n1 | cut -f1)"
    else
      selected="$(printf '%s\n' "$files" | column -t -s $'\t' | fzf --header='file quant size' | awk '{print $1}')"
    fi
  fi
  [[ -n "$selected" ]] || die "no file selected"
  mkdir -p "$MODELS_DIR"
  local downloaded="$MODELS_DIR/$selected"
  if [[ -n "$local_name" ]]; then
    downloaded="$MODELS_DIR/${local_name%.gguf}.gguf"
    [[ -e "$downloaded" ]] && die "$downloaded already exists"
  fi
  download_hf_file "$repo" "$selected" "$downloaded"
  if [[ "$register" -eq 1 ]]; then
    model_id="${model_id:-$(sanitize_model_id "${local_name:-$selected}")}"
    register_model "$model_id" "$downloaded" "$aliases_json" "$ctx" "$gpu_layers" "$batch" "$ubatch" "$ttl" "hf:$repo/$selected"
    if [[ "$JSON_OUTPUT" -eq 1 ]]; then
      jq -cn --arg id "$model_id" --arg path "$downloaded" '{id:$id,path:$path,registered:true}'
    else
      echo "downloaded: $downloaded"
      echo "registered: $model_id"
    fi
    return
  fi
  if [[ "$JSON_OUTPUT" -eq 1 ]]; then
    jq -cn --arg path "$downloaded" '{path:$path,registered:false}'
  else
    echo "$downloaded"
  fi
}

cmd_cache() {
  require_cmd hf
  [[ $# -ge 1 ]] || die "usage: llm cache ls|prune"
  case "$1" in
    ls) hf cache ls ;;
    prune) hf cache prune ;;
    *) die "usage: llm cache ls|prune" ;;
  esac
}

cmd_ls() {
  require_cmd jq
  ensure_registry
  local filter="all" long=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --long) long=1; shift ;;
      --registered) filter="registered"; shift ;;
      --unregistered) filter="unregistered"; shift ;;
      --enabled) filter="enabled"; shift ;;
      --disabled) filter="disabled"; shift ;;
      --missing) filter="missing"; shift ;;
      *) die "usage: llm ls [--long|--registered|--unregistered|--enabled|--disabled|--missing]" ;;
    esac
  done

  local rows="" json_rows="[]" found=0
  if [[ "$long" -eq 1 ]]; then
    rows+=$'state\tid\tsize\tctx\tgpu\tttl\taliases\tpath\n'
  else
    rows+=$'state\tid\tsize\tctx\tgpu\tttl\taliases\n'
  fi

  add_ls_row() {
    local state="$1" id="$2" path="$3" ctx="$4" gpu="$5" ttl="$6" source="$7" aliases="$8"
    local size="missing"
    if [[ -f "$path" ]]; then
      size="$(du -h "$path" | awk '{print $1}')"
    fi
    case "$filter" in
      all) ;;
      registered) [[ "$state" != "unregistered" ]] || return ;;
      unregistered) [[ "$state" == "unregistered" ]] || return ;;
      enabled) [[ "$state" == "enabled" ]] || return ;;
      disabled) [[ "$state" == "disabled" ]] || return ;;
      missing) [[ "$state" == "missing" ]] || return ;;
    esac
    found=1
    json_rows="$(jq -cn \
      --argjson old "$json_rows" \
      --arg state "$state" \
      --arg id "$id" \
      --arg path "$path" \
      --arg size "$size" \
      --arg ctx "$ctx" \
      --arg gpu "$gpu" \
      --arg ttl "$ttl" \
      --arg source "$source" \
      --arg aliases "$aliases" \
      '$old + [{state:$state,id:$id,path:$path,size:$size,ctx:$ctx,gpuLayers:$gpu,ttl:$ttl,source:$source,aliases:($aliases | split(",") | map(select(. != "" and . != "-")))}]')"
    if [[ "$long" -eq 1 ]]; then
      rows+="${state}"$'\t'"${id}"$'\t'"${size}"$'\t'"${ctx}"$'\t'"${gpu}"$'\t'"${ttl}"$'\t'"${aliases}"$'\t'"${path}"$'\n'
    else
      rows+="${state}"$'\t'"${id}"$'\t'"${size}"$'\t'"${ctx}"$'\t'"${gpu}"$'\t'"${ttl}"$'\t'"${aliases}"$'\n'
    fi
  }

  while IFS=$'\t' read -r id path enabled ctx gpu ttl source aliases; do
    [[ -n "$id" ]] || continue
    local state="enabled"
    [[ "$enabled" == "false" ]] && state="disabled"
    [[ -f "$path" ]] || state="missing"
    add_ls_row "$state" "$id" "$path" "$ctx" "$gpu" "$ttl" "$source" "$aliases"
  done < <(jq -r --argjson defaultCtx "$DEFAULT_CTX" '
    .models
    | to_entries[]
    | [
      .key,
      .value.path,
      (.value.enabled // true | tostring),
      (.value.ctx // $defaultCtx | tostring),
      (if (.value.fitTarget // "") != "" then "auto" elif (.value | has("gpuLayers")) then (.value.gpuLayers | tostring) else "99" end),
      (.value.ttl // 600 | tostring),
      (.value.source // "manual"),
      ((.value.aliases // []) | join(","))
    ]
    | @tsv
  ' "$MODELS_JSON")

  while IFS= read -r file; do
    [[ -n "$file" ]] || continue
    if jq -e --arg path "$file" '.models | to_entries[] | select(.value.path == $path)' "$MODELS_JSON" >/dev/null; then
      continue
    fi
    add_ls_row "unregistered" "-" "$file" "-" "-" "-" "-" "-"
  done < <(find "$MODELS_DIR" -type f -name '*.gguf' -print | sort)

  if [[ "$JSON_OUTPUT" -eq 1 ]]; then
    printf '%s\n' "$json_rows" | jq .
    return
  fi
  if [[ "$found" -eq 0 ]]; then
    echo "no models found"
    return
  fi
  printf '%s' "$rows" | column -t -s $'\t'
}

cmd_add() {
  require_cmd jq
  ensure_registry
  [[ $# -ge 3 ]] || die "usage: llm add <path> --id <id> [--alias alias] [--ctx n] [--gpu-layers n] [--batch n] [--ubatch n] [--ttl 10m]"
  local path id="" ctx="$DEFAULT_CTX" gpu_layers=99 batch="$DEFAULT_BATCH" ubatch="$DEFAULT_UBATCH" ttl=600 aliases_json="[]"
  path="$(assert_under_llm_root "$1")"
  [[ -f "$path" ]] || die "$path does not exist"
  shift
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) id="$2"; shift 2 ;;
      --alias) aliases_json="$(jq -cn --argjson old "$aliases_json" --arg alias "$2" '$old + [$alias]')"; shift 2 ;;
      --ctx) ctx="$2"; shift 2 ;;
      --gpu-layers) gpu_layers="$2"; shift 2 ;;
      --batch) batch="$2"; shift 2 ;;
      --ubatch) ubatch="$2"; shift 2 ;;
      --ttl) ttl="$(parse_ttl "$2")"; shift 2 ;;
      *) die "unknown add option: $1" ;;
    esac
  done
  [[ -n "$id" ]] || die "--id is required"
  register_model "$id" "$path" "$aliases_json" "$ctx" "$gpu_layers" "$batch" "$ubatch" "$ttl" "manual"
  echo "added: $id"
}

cmd_set() {
  require_cmd jq
  ensure_registry
  local id="" ctx="" gpu_layers="" batch="" ubatch="" mmap="" flash_attn="" fit_target="" ttl="" tmp
  local cpu_moe="" cache_type_k="" cache_type_v="" threads="" threads_batch="" split_mode="" tensor_split="" main_gpu="" no_kv_offload="" mlock=""
  local draft_clear=0 draft_model="" draft_hf="" draft_n_max="" draft_n_min="" draft_ctx="" draft_gpu_layers="" draft_cache_type_k="" draft_cache_type_v=""
  local server_args_json="[]" env_json="{}"
  if [[ $# -gt 0 && "$1" != --* ]]; then
    id="$(model_id_from_alias "$1")"
    shift
  else
    id="$(model_id_or_select "set" 1)"
  fi
  [[ $# -gt 0 ]] || die "usage: llm set [id] [runtime options]"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ctx) ctx="$2"; shift 2 ;;
      --gpu-layers) gpu_layers="$2"; shift 2 ;;
      --batch) batch="$2"; shift 2 ;;
      --ubatch) ubatch="$2"; shift 2 ;;
      --mmap) mmap="true"; shift ;;
      --no-mmap) mmap="false"; shift ;;
      --flash-attn)
        case "$2" in
          on|off|auto) flash_attn="$2" ;;
          *) die "--flash-attn must be on, off, or auto" ;;
        esac
        shift 2
        ;;
      --fit-target)
        case "$2" in
          default|auto|unset|off) fit_target="default" ;;
          *) fit_target="$DEFAULT_FIT_TARGET" ;;
        esac
        shift 2
        ;;
      --cpu-moe) cpu_moe="$2"; shift 2 ;;
      --cache-type-k) cache_type_k="$2"; shift 2 ;;
      --cache-type-v) cache_type_v="$2"; shift 2 ;;
      --draft)
        case "${2:-}" in
          off|none|default|unset) draft_clear=1 ;;
          *) die "--draft currently supports off only" ;;
        esac
        shift 2
        ;;
      --draft-model) draft_model="$2"; draft_clear=0; shift 2 ;;
      --draft-hf) draft_hf="$2"; draft_clear=0; shift 2 ;;
      --draft-n-max) draft_n_max="$2"; draft_clear=0; shift 2 ;;
      --draft-n-min) draft_n_min="$2"; draft_clear=0; shift 2 ;;
      --draft-ctx) draft_ctx="$2"; draft_clear=0; shift 2 ;;
      --draft-gpu-layers) draft_gpu_layers="$2"; draft_clear=0; shift 2 ;;
      --draft-cache-type-k) draft_cache_type_k="$2"; draft_clear=0; shift 2 ;;
      --draft-cache-type-v) draft_cache_type_v="$2"; draft_clear=0; shift 2 ;;
      --threads) threads="$2"; shift 2 ;;
      --threads-batch) threads_batch="$2"; shift 2 ;;
      --split-mode) split_mode="$2"; shift 2 ;;
      --tensor-split) tensor_split="$2"; shift 2 ;;
      --main-gpu) main_gpu="$2"; shift 2 ;;
      --no-kv-offload)
        if [[ $# -eq 1 || "${2:-}" == --* ]]; then
          no_kv_offload="true"
          shift
        else
          case "$2" in
            on|true|1) no_kv_offload="true" ;;
            off|false|0) no_kv_offload="false" ;;
            *) die "--no-kv-offload must be on or off" ;;
          esac
          shift 2
        fi
        ;;
      --mlock)
        if [[ $# -eq 1 || "${2:-}" == --* ]]; then
          mlock="true"
          shift
        else
          case "$2" in
            on|true|1) mlock="true" ;;
            off|false|0) mlock="false" ;;
            *) die "--mlock must be on or off" ;;
          esac
          shift 2
        fi
        ;;
      --server-arg)
        server_args_json="$(jq -cn --argjson old "$server_args_json" --arg value "$2" '$old + [$value]')"
        shift 2
        ;;
      --env)
        [[ "$2" == *=* ]] || die "--env expects KEY=VALUE"
        local env_key="${2%%=*}" env_value="${2#*=}"
        [[ -n "$env_key" ]] || die "--env expects KEY=VALUE"
        env_json="$(jq -cn --argjson old "$env_json" --arg key "$env_key" --arg value "$env_value" '$old + {($key): $value}')"
        shift 2
        ;;
      --ttl) ttl="$(parse_ttl "$2")"; shift 2 ;;
      *) die "unknown set option: $1" ;;
    esac
  done
  log "updating: $id"
  tmp="$(mktemp "$REGISTRY_DIR/models.json.tmp.XXXXXX")"
  jq \
    --arg id "$id" \
    --arg ctx "$ctx" \
    --arg gpuLayers "$gpu_layers" \
    --arg batch "$batch" \
    --arg ubatch "$ubatch" \
    --arg mmap "$mmap" \
    --arg flashAttn "$flash_attn" \
    --arg fitTarget "$fit_target" \
    --arg cpuMoe "$cpu_moe" \
    --arg cacheTypeK "$cache_type_k" \
    --arg cacheTypeV "$cache_type_v" \
    --arg threads "$threads" \
    --arg threadsBatch "$threads_batch" \
    --arg splitMode "$split_mode" \
    --arg tensorSplit "$tensor_split" \
    --arg mainGpu "$main_gpu" \
    --arg noKvOffload "$no_kv_offload" \
    --arg mlock "$mlock" \
    --arg draftClear "$draft_clear" \
    --arg draftModel "$draft_model" \
    --arg draftHf "$draft_hf" \
    --arg draftNMax "$draft_n_max" \
    --arg draftNMin "$draft_n_min" \
    --arg draftCtx "$draft_ctx" \
    --arg draftGpuLayers "$draft_gpu_layers" \
    --arg draftCacheTypeK "$draft_cache_type_k" \
    --arg draftCacheTypeV "$draft_cache_type_v" \
    --argjson serverArgs "$server_args_json" \
    --argjson env "$env_json" \
    --arg ttl "$ttl" \
    '
      .models[$id] |= (
        if $ctx != "" then .ctx = ($ctx | tonumber) else . end
        | if $gpuLayers == "default" then del(.gpuLayers) elif $gpuLayers != "" then .gpuLayers = ($gpuLayers | tonumber) else . end
        | if $batch != "" then .batch = ($batch | tonumber) else . end
        | if $ubatch != "" then .ubatch = ($ubatch | tonumber) else . end
        | if $mmap != "" then .mmap = ($mmap == "true") else . end
        | if $flashAttn != "" then .flashAttn = $flashAttn else . end
        | if $fitTarget == "default" then del(.fitTarget) elif $fitTarget != "" then .fitTarget = ($fitTarget | tonumber) else . end
        | if $cpuMoe != "" then .cpuMoe = ($cpuMoe | tonumber) else . end
        | if $cacheTypeK != "" then .cacheTypeK = $cacheTypeK else . end
        | if $cacheTypeV != "" then .cacheTypeV = $cacheTypeV else . end
        | if $threads != "" then .threads = ($threads | tonumber) else . end
        | if $threadsBatch != "" then .threadsBatch = ($threadsBatch | tonumber) else . end
        | if $splitMode != "" then .splitMode = $splitMode else . end
        | if $tensorSplit != "" then .tensorSplit = $tensorSplit else . end
        | if $mainGpu != "" then .mainGpu = ($mainGpu | tonumber) else . end
        | if $noKvOffload != "" then .noKvOffload = ($noKvOffload == "true") else . end
        | if $mlock != "" then .mlock = ($mlock == "true") else . end
        | if $draftClear == "1" then del(.draft) else . end
        | if $draftModel != "" then .draft.model = $draftModel else . end
        | if $draftHf != "" then .draft.hf = $draftHf else . end
        | if $draftNMax != "" then .draft.nMax = ($draftNMax | tonumber) else . end
        | if $draftNMin != "" then .draft.nMin = ($draftNMin | tonumber) else . end
        | if $draftCtx != "" then .draft.ctx = ($draftCtx | tonumber) else . end
        | if $draftGpuLayers != "" then .draft.gpuLayers = ($draftGpuLayers | tonumber) else . end
        | if $draftCacheTypeK != "" then .draft.cacheTypeK = $draftCacheTypeK else . end
        | if $draftCacheTypeV != "" then .draft.cacheTypeV = $draftCacheTypeV else . end
        | if ($serverArgs | length) > 0 then .serverArgs = $serverArgs else . end
        | if ($env | length) > 0 then .env = ((.env // {}) + $env) else . end
        | if $ttl != "" then .ttl = ($ttl | tonumber) else . end
      )
    ' "$MODELS_JSON" >"$tmp"
  mv "$tmp" "$MODELS_JSON"
  render_config
  registry_entry "$id" | jq -r --arg id "$id" --argjson defaultCtx "$DEFAULT_CTX" --argjson defaultBatch "$DEFAULT_BATCH" --argjson defaultUbatch "$DEFAULT_UBATCH" --argjson defaultFitTarget "$DEFAULT_FIT_TARGET" '"updated: \($id)\nctx: \(.ctx // $defaultCtx)\ngpuLayers: \(if (.fitTarget // "") != "" then "auto" elif has("gpuLayers") then .gpuLayers else 99 end)\nbatch: \(.batch // $defaultBatch)\nubatch: \(.ubatch // $defaultUbatch)\nmmap: \(if has("mmap") then .mmap else "default" end)\nflashAttn: \(.flashAttn // "default")\nfitTarget: \(if (.fitTarget // "") != "" then $defaultFitTarget else "default" end)\ncpuMoe: \(.cpuMoe // "default")\ncacheTypeK: \(.cacheTypeK // "default")\ncacheTypeV: \(.cacheTypeV // "default")\nthreads: \(.threads // "default")\nthreadsBatch: \(.threadsBatch // "default")\nsplitMode: \(.splitMode // "default")\ntensorSplit: \(.tensorSplit // "default")\nmainGpu: \(.mainGpu // "default")\nnoKvOffload: \(.noKvOffload // "default")\nmlock: \(.mlock // "default")\ndraft: \((.draft // "default") | if type == "object" then tojson else tostring end)\nserverArgs: \((.serverArgs // []) | join(" "))\nenv: \((.env // {}) | to_entries | map(.key + "=" + .value) | join(" "))\nttl: \(.ttl // 600)"'
}

cmd_edit() {
  require_cmd jq
  ensure_registry
  [[ $# -le 1 ]] || die "usage: llm edit [id]"
  local id tmp
  id="$(model_id_or_select "edit" 1 "${1:-}")"
  tmp="$(mktemp)"
  registry_entry "$id" >"$tmp"
  "${EDITOR:-vim}" "$tmp"
  jq -e . "$tmp" >/dev/null
  local out
  out="$(mktemp "$REGISTRY_DIR/models.json.tmp.XXXXXX")"
  jq --arg id "$id" --slurpfile entry "$tmp" '.models[$id] = $entry[0]' "$MODELS_JSON" >"$out"
  mv "$out" "$MODELS_JSON"
  rm -f "$tmp"
  render_config
  echo "edited: $id"
}

set_enabled() {
  require_cmd jq
  ensure_registry
  [[ $# -ge 1 && $# -le 2 ]] || die "usage: llm enable|disable [id]"
  local id enabled tmp
  enabled="$1"
  id="$(model_id_or_select "model" 1 "${2:-}")"
  if [[ "$enabled" == "true" ]]; then
    log "enabling: $id"
  else
    log "disabling: $id"
  fi
  tmp="$(mktemp "$REGISTRY_DIR/models.json.tmp.XXXXXX")"
  jq --arg id "$id" --argjson enabled "$enabled" '.models[$id].enabled = $enabled' "$MODELS_JSON" >"$tmp"
  mv "$tmp" "$MODELS_JSON"
  log "regenerating llama-swap config"
  render_config
}

api_json() {
  local path="$1"
  curl -fsS -H "authorization: Bearer $OPENAI_KEY" "$API_BASE$path"
}

owned_llama_server_pids() {
  local pid cmdline
  while IFS= read -r pid; do
    [[ -n "$pid" && -r "/proc/$pid/cmdline" ]] || continue
    cmdline="$(tr '\0' ' ' <"/proc/$pid/cmdline" 2>/dev/null || true)"
    [[ "$cmdline" == *"llama-server"* && "$cmdline" == *"$MODELS_DIR/"* ]] || continue
    printf '%s\n' "$pid"
  done < <(pgrep -x llama-server || true)
}

clear_runtime() {
  local pids still_running=()
  log "requesting llama-swap unload"
  curl -fsS -H "authorization: Bearer $OPENAI_KEY" "$API_BASE/unload" >/dev/null 2>&1 || true
  sleep 1
  mapfile -t pids < <(owned_llama_server_pids)
  if [[ "${#pids[@]}" -eq 0 ]]; then
    log "no stale llama-server processes found"
    return
  fi
  log "terminating stale llama-server pids: ${pids[*]}"
  kill "${pids[@]}" 2>/dev/null || true
  sleep 2
  mapfile -t still_running < <(owned_llama_server_pids)
  if [[ "${#still_running[@]}" -gt 0 ]]; then
    log "force-killing stale llama-server pids: ${still_running[*]}"
    kill -9 "${still_running[@]}" 2>/dev/null || true
  fi
}

chat_request() {
  local model="$1" prompt="$2" max_tokens="${3:-128}"
  jq -cn --arg model "$model" --arg prompt "$prompt" --argjson max "$max_tokens" \
    '{model:$model,max_tokens:$max,messages:[{role:"user",content:$prompt}]}'
}

bench_request() {
  local model="$1" prompt="$2" max_tokens="$3"
  jq -cn --arg model "$model" --arg prompt "$prompt" --argjson max "$max_tokens" \
    '{model:$model,max_tokens:$max,temperature:0,messages:[{role:"user",content:$prompt}]}'
}

post_chat() {
  local body status
  body="$(mktemp)"
  status="$(curl -sS -o "$body" -w '%{http_code}' "$API_BASE/v1/chat/completions" -H 'content-type: application/json' -H "authorization: Bearer $OPENAI_KEY" -d @- || true)"
  if [[ "$status" =~ ^2 ]]; then
    cat "$body"
    rm -f "$body"
    return 0
  fi
  echo "error: llama-swap returned HTTP $status" >&2
  sed -n '1,20p' "$body" >&2
  rm -f "$body"
  return 1
}

warm_served_model() {
  local id="$1" attempts="${2:-30}" output=""
  for attempt in $(seq 1 "$attempts"); do
    if output="$({ chat_request "$id" "ping" 4 | post_chat >/dev/null; } 2>&1)"; then
      return 0
    fi
    if (( attempt % 10 == 0 )); then
      log "still warming model: ${attempt}s elapsed"
    fi
    sleep 1
  done
  [[ -n "$output" ]] && echo "$output" >&2
  return 1
}

bench_prompt() {
  local prompt_tokens="$1" gen_tokens="$2"
  jq -rn --argjson promptTokens "$prompt_tokens" --argjson genTokens "$gen_tokens" '
    "Output exactly \($genTokens) short tokens. Use the word ok repeatedly, separated by spaces. Do not explain.\n\n"
    + ([range(0; $promptTokens)] | map("ok") | join(" "))
  '
}

bench_metrics() {
  local model="$1" requested_prompt_tokens="$2" requested_gen_tokens="$3" elapsed_ms="$4" response="$5"
  jq -cn \
    --arg model "$model" \
    --argjson requestedPrompt "$requested_prompt_tokens" \
    --argjson requestedGen "$requested_gen_tokens" \
    --argjson elapsedMs "$elapsed_ms" \
    --argjson response "$response" '
      def rate($tokens; $seconds):
        if ($tokens != null and $seconds > 0) then ($tokens / $seconds) else null end;
      ($elapsedMs / 1000) as $elapsedSeconds
      | ($response.usage // {}) as $usage
      | ($response.timings // {}) as $timings
      | ($usage.prompt_tokens // $timings.prompt_n // null) as $promptTokens
      | ($usage.completion_tokens // $timings.predicted_n // null) as $completionTokens
      | ($usage.total_tokens // (if ($promptTokens != null and $completionTokens != null) then ($promptTokens + $completionTokens) else null end)) as $totalTokens
      | ($timings.predicted_per_second // (if (($timings.predicted_n // null) != null and ($timings.predicted_ms // null) != null and $timings.predicted_ms > 0) then ($timings.predicted_n / ($timings.predicted_ms / 1000)) else null end)) as $serverGeneratedTps
      | {
          model: $model,
          requested_prompt_tokens: $requestedPrompt,
          requested_gen_tokens: $requestedGen,
          elapsed_ms: $elapsedMs,
          elapsed_seconds: $elapsedSeconds,
          prompt_tokens: $promptTokens,
          completion_tokens: $completionTokens,
          total_tokens: $totalTokens,
          generated_tok_s: rate($completionTokens; $elapsedSeconds),
          total_tok_s: rate($totalTokens; $elapsedSeconds),
          server_prompt_tok_s: ($timings.prompt_per_second // null),
          server_generated_tok_s: $serverGeneratedTps,
          response_chars: (($response.choices[0].message.content // $response.choices[0].text // "") | length),
          response_preview: (($response.choices[0].message.content // $response.choices[0].text // "") | gsub("\\s+"; " ") | .[0:200])
        }
    '
}

diagnose_start_failure() {
  local id="$1" path ctx gpu batch ubatch mmap flash_attn fit_target port
  local cpu_moe cache_type_k cache_type_v threads threads_batch split_mode tensor_split main_gpu no_kv_offload mlock
  local draft_model draft_hf draft_n_max draft_n_min draft_ctx draft_gpu_layers draft_cache_type_k draft_cache_type_v
  path="$(model_path "$id")"
  ctx="$(jq -r --arg id "$id" --argjson defaultCtx "$DEFAULT_CTX" '.models[$id].ctx // $defaultCtx' "$MODELS_JSON")"
  gpu="$(jq -r --arg id "$id" 'if (.models[$id].fitTarget // "") != "" then empty elif .models[$id] | has("gpuLayers") then .models[$id].gpuLayers else 99 end' "$MODELS_JSON")"
  batch="$(jq -r --arg id "$id" --argjson defaultBatch "$DEFAULT_BATCH" '.models[$id].batch // $defaultBatch' "$MODELS_JSON")"
  ubatch="$(jq -r --arg id "$id" --argjson defaultUbatch "$DEFAULT_UBATCH" '.models[$id].ubatch // $defaultUbatch' "$MODELS_JSON")"
  mmap="$(jq -r --arg id "$id" 'if .models[$id] | has("mmap") then .models[$id].mmap else empty end' "$MODELS_JSON")"
  flash_attn="$(jq -r --arg id "$id" '.models[$id].flashAttn // empty' "$MODELS_JSON")"
  fit_target="$(jq -r --arg id "$id" '.models[$id].fitTarget // empty' "$MODELS_JSON")"
  cpu_moe="$(jq -r --arg id "$id" '.models[$id].cpuMoe // empty' "$MODELS_JSON")"
  cache_type_k="$(jq -r --arg id "$id" '.models[$id].cacheTypeK // empty' "$MODELS_JSON")"
  cache_type_v="$(jq -r --arg id "$id" '.models[$id].cacheTypeV // empty' "$MODELS_JSON")"
  threads="$(jq -r --arg id "$id" '.models[$id].threads // empty' "$MODELS_JSON")"
  threads_batch="$(jq -r --arg id "$id" '.models[$id].threadsBatch // empty' "$MODELS_JSON")"
  split_mode="$(jq -r --arg id "$id" '.models[$id].splitMode // empty' "$MODELS_JSON")"
  tensor_split="$(jq -r --arg id "$id" '.models[$id].tensorSplit // empty' "$MODELS_JSON")"
  main_gpu="$(jq -r --arg id "$id" '.models[$id].mainGpu // empty' "$MODELS_JSON")"
  no_kv_offload="$(jq -r --arg id "$id" '.models[$id].noKvOffload // empty' "$MODELS_JSON")"
  mlock="$(jq -r --arg id "$id" '.models[$id].mlock // empty' "$MODELS_JSON")"
  draft_model="$(jq -r --arg id "$id" '.models[$id].draft.model // empty' "$MODELS_JSON")"
  draft_hf="$(jq -r --arg id "$id" '.models[$id].draft.hf // empty' "$MODELS_JSON")"
  draft_n_max="$(jq -r --arg id "$id" '.models[$id].draft.nMax // empty' "$MODELS_JSON")"
  draft_n_min="$(jq -r --arg id "$id" '.models[$id].draft.nMin // empty' "$MODELS_JSON")"
  draft_ctx="$(jq -r --arg id "$id" '.models[$id].draft.ctx // empty' "$MODELS_JSON")"
  draft_gpu_layers="$(jq -r --arg id "$id" '.models[$id].draft.gpuLayers // empty' "$MODELS_JSON")"
  draft_cache_type_k="$(jq -r --arg id "$id" '.models[$id].draft.cacheTypeK // empty' "$MODELS_JSON")"
  draft_cache_type_v="$(jq -r --arg id "$id" '.models[$id].draft.cacheTypeV // empty' "$MODELS_JSON")"
  port="${LLM_DIAG_PORT:-12999}"
  local args=(--host 127.0.0.1 --port "$port" --model "$path" --ctx-size "$ctx")
  [[ -n "$gpu" ]] && args+=(--n-gpu-layers "$gpu")
  args+=(--batch-size "$batch" --ubatch-size "$ubatch")
  if [[ "$mmap" == "false" ]]; then
    args+=(--no-mmap)
  elif [[ "$mmap" == "true" ]]; then
    args+=(--mmap)
  fi
  if [[ -n "$flash_attn" ]]; then
    args+=(--flash-attn "$flash_attn")
  fi
  if [[ -n "$fit_target" ]]; then
    args+=(--fit on)
    args+=(--fit-target "$DEFAULT_FIT_TARGET")
    args+=(--fit-ctx "$ctx")
  else
    args+=(--fit off)
  fi
  [[ -n "$cpu_moe" ]] && args+=(--n-cpu-moe "$cpu_moe")
  [[ -n "$cache_type_k" ]] && args+=(--cache-type-k "$cache_type_k")
  [[ -n "$cache_type_v" ]] && args+=(--cache-type-v "$cache_type_v")
  [[ -n "$threads" ]] && args+=(--threads "$threads")
  [[ -n "$threads_batch" ]] && args+=(--threads-batch "$threads_batch")
  [[ -n "$split_mode" ]] && args+=(--split-mode "$split_mode")
  [[ -n "$tensor_split" ]] && args+=(--tensor-split "$tensor_split")
  [[ -n "$main_gpu" ]] && args+=(--main-gpu "$main_gpu")
  [[ "$no_kv_offload" == "true" ]] && args+=(--no-kv-offload)
  [[ "$mlock" == "true" ]] && args+=(--mlock)
  [[ -n "$draft_model" ]] && args+=(--model-draft "$draft_model")
  [[ -n "$draft_hf" ]] && args+=(--hf-repo-draft "$draft_hf")
  [[ -n "$draft_n_max" ]] && args+=(--spec-draft-n-max "$draft_n_max")
  [[ -n "$draft_n_min" ]] && args+=(--spec-draft-n-min "$draft_n_min")
  [[ -n "$draft_ctx" ]] && args+=(--spec-draft-ctx-size "$draft_ctx")
  [[ -n "$draft_gpu_layers" ]] && args+=(--n-gpu-layers-draft "$draft_gpu_layers")
  [[ -n "$draft_cache_type_k" ]] && args+=(--cache-type-k-draft "$draft_cache_type_k")
  [[ -n "$draft_cache_type_v" ]] && args+=(--cache-type-v-draft "$draft_cache_type_v")
  while IFS= read -r extra_arg; do
    [[ -n "$extra_arg" ]] && args+=("$extra_arg")
  done < <(jq -r --arg id "$id" '.models[$id].serverArgs[]? // empty' "$MODELS_JSON")
  echo "diagnostic: llama-server ${args[*]}" >&2
  if have timeout && have llama-server; then
    timeout 15 llama-server "${args[@]}" 2>&1 |
      grep -Ei 'error|failed|wrong|invalid|unsupported|cuda|exiting' |
      tail -30 >&2 || true
  fi
  if have journalctl; then
    echo "recent llama-swap logs:" >&2
    journalctl -u llama-swap -n 20 --no-pager 2>/dev/null >&2 || true
  fi
}

cmd_start() {
  [[ $# -le 1 ]] || die "usage: llm start [id]"
  local id
  id="$(model_id_or_select "start" 0 "${1:-}" "chat")"
  require_startable_model "$id"
  log "starting: $id"
  clear_runtime
  set_enabled true "$id" >/dev/null
  log "waiting for llama-swap to serve: $id"
  if ! wait_for_served_model "$id"; then
    echo "error: llama-swap did not serve $id after config reload" >&2
    return 1
  fi
  log "warming model with a chat request"
  if ! warm_served_model "$id"; then
    diagnose_start_failure "$id"
    return 1
  fi
  echo "started: $id"
}

cmd_stop() {
  [[ $# -le 1 ]] || die "usage: llm stop [id]"
  local id
  if [[ -n "${1:-}" ]]; then
    id="$(model_id_from_alias "$1")"
  else
    id="$(select_loaded_model_id "stop")"
  fi
  log "stopping: $id"
  set_enabled false "$id" >/dev/null
  clear_runtime
  echo "stopped: $id"
}

cmd_clear() {
  clear_runtime
  echo "cleared llama runtime"
}

cmd_rm() {
  require_cmd jq
  ensure_registry
  local dry_run=0 target="${1:-}"
  [[ -n "$target" ]] || die "usage: llm rm <id|path> [--dry-run]"
  shift || true
  [[ "${1:-}" == "--dry-run" ]] && dry_run=1
  local path id=""
  if registry_entry "$target" >/dev/null 2>&1 || model_id_from_alias "$target" >/dev/null 2>&1; then
    id="$(model_id_from_alias "$target")"
    path="$(model_path "$id")"
  else
    path="$(assert_under_llm_root "$target")"
  fi
  path="$(assert_under_llm_root "$path")"
  if [[ "$dry_run" -eq 1 ]]; then
    echo "would remove: $path"
    [[ -n "$id" ]] && echo "would unregister: $id"
    return
  fi
  rm -f "$path"
  if [[ -n "$id" ]]; then
    local tmp
    tmp="$(mktemp "$REGISTRY_DIR/models.json.tmp.XXXXXX")"
    jq --arg id "$id" 'del(.models[$id])' "$MODELS_JSON" >"$tmp"
    mv "$tmp" "$MODELS_JSON"
    render_config
  fi
  echo "removed: $path"
}

cmd_status() {
  local swap_state="unknown" webui_state="unknown" health="down" running_json served_json stale_pids
  if have systemctl; then
    swap_state="$(systemctl is-active llama-swap 2>/dev/null || true)"
    webui_state="$(systemctl is-active open-webui 2>/dev/null || true)"
  fi
  if api_json /health >/dev/null 2>&1; then
    health="ok"
  fi

  echo "services:"
  printf '  llama-swap: %s\n' "${swap_state:-unknown}"
  printf '  open-webui: %s\n' "${webui_state:-unknown}"
  printf '  api: %s (%s)\n' "$health" "$API_BASE"

  echo
  echo "loaded:"
  running_json="$(api_json /running 2>/dev/null || true)"
  if [[ -n "$running_json" ]] && jq -e '.running | length > 0' >/dev/null 2>&1 <<<"$running_json"; then
    jq -r '
      .running[]
      | [
        (.model // "-"),
        (.state // "-"),
        (.proxy // "-"),
        (.ttl // "-" | tostring)
      ]
      | @tsv
    ' <<<"$running_json" | column -t -s $'\t' | sed 's/^/  /'
  else
    echo "  none"
  fi

  echo
  echo "served:"
  served_json="$(api_json /v1/models 2>/dev/null || true)"
  if [[ -n "$served_json" ]] && jq -e '.data | length > 0' >/dev/null 2>&1 <<<"$served_json"; then
    jq -r '.data[]?.id' <<<"$served_json" | sed 's/^/  /'
  else
    echo "  none"
  fi

  echo
  echo "gpu:"
  if have nvidia-smi; then
    nvidia-smi --query-gpu=memory.total,memory.used,memory.free --format=csv,noheader,nounits |
      awk -F ', ' '{printf "  vram: %s MiB used / %s MiB total (%s MiB free)\n", $2, $1, $3}'
  else
    echo "  nvidia-smi unavailable"
  fi

  echo
  echo "processes:"
  stale_pids="$(owned_llama_server_pids | paste -sd ' ' -)"
  if [[ -n "$stale_pids" ]]; then
    for pid in $stale_pids; do
      printf '  pid %s: ' "$pid"
      tr '\0' ' ' <"/proc/$pid/cmdline" 2>/dev/null | sed 's/  */ /g'
      echo
    done
  else
    echo "  no local llama-server processes"
  fi
}

cmd_logs() {
  journalctl -u llama-swap -f
}

cmd_served() {
  api_json /v1/models | jq .
}

cmd_ps() {
  if api_json /running 2>/dev/null | jq .; then
    return
  fi
  owned_llama_server_pids | while read -r pid; do
    printf '%s ' "$pid"
    tr '\0' ' ' <"/proc/$pid/cmdline" 2>/dev/null
    echo
  done
}

cmd_test() {
  [[ $# -le 1 ]] || die "usage: llm test [id]"
  local id
  if [[ -n "${1:-}" ]]; then
    id="$(model_id_from_alias "$1")"
  else
    id="$(select_loaded_model_id "test")"
  fi
  require_startable_model "$id"
  log "testing: $id"
  local response
  response="$(chat_request "$id" "Respond with the single word OK." 128 | post_chat | jq -r '.choices[0].message.content // .choices[0].text // empty')"
  [[ -n "$response" ]] || die "test returned empty response"
  printf '%s\n' "$response"
}

cmd_chat() {
  [[ $# -ge 1 ]] || die "usage: llm chat [id] <prompt>"
  local model
  if model_id_from_alias "$1" >/dev/null 2>&1; then
    model="$(model_id_from_alias "$1")"
    require_startable_model "$model"
    shift
    [[ $# -ge 1 ]] || die "usage: llm chat [id] <prompt>"
  else
    model="$(select_loaded_model_id "chat")"
  fi
  log "chat: $model"
  chat_request "$model" "$*" 512 | post_chat | jq -r '.choices[0].message.content // .choices[0].text // .'
}

cmd_bench() {
  require_cmd jq
  local id="" prompt="" prompt_tokens="${LLM_BENCH_PROMPT_TOKENS:-2048}" gen_tokens="${LLM_BENCH_GEN_TOKENS:-512}"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --prompt-tokens)
        [[ $# -ge 2 ]] || die "--prompt-tokens needs a value"
        prompt_tokens="$2"
        shift 2
        ;;
      --gen-tokens|--max-tokens)
        [[ $# -ge 2 ]] || die "$1 needs a value"
        gen_tokens="$2"
        shift 2
        ;;
      --help|-h)
        echo "usage: llm bench [id] [--prompt-tokens n] [--gen-tokens n] [prompt]"
        return
        ;;
      --*)
        die "unknown bench option: $1"
        ;;
      *)
        if [[ -z "$id" ]] && model_id_from_alias "$1" >/dev/null 2>&1; then
          id="$(model_id_from_alias "$1")"
          shift
        else
          prompt="$*"
          break
        fi
        ;;
    esac
  done
  [[ "$prompt_tokens" =~ ^[0-9]+$ && "$prompt_tokens" -gt 0 ]] || die "--prompt-tokens must be a positive integer"
  [[ "$gen_tokens" =~ ^[0-9]+$ && "$gen_tokens" -gt 0 ]] || die "--gen-tokens must be a positive integer"
  [[ -n "$id" ]] || id="$(select_loaded_model_id "bench")"
  require_startable_model "$id"
  [[ -n "$prompt" ]] || prompt="$(bench_prompt "$prompt_tokens" "$gen_tokens")"

  local start end elapsed_ms response metrics
  log "benchmarking: $id"
  start="$(date +%s%3N)"
  response="$(bench_request "$id" "$prompt" "$gen_tokens" | post_chat)"
  end="$(date +%s%3N)"
  elapsed_ms="$((end - start))"
  metrics="$(bench_metrics "$id" "$prompt_tokens" "$gen_tokens" "$elapsed_ms" "$response")"
  if [[ "$JSON_OUTPUT" -eq 1 ]]; then
    echo "$metrics"
    return
  fi
  echo "$metrics" | jq -r '
    def num:
      if . == null then "-"
      elif . >= 100 then ((. * 10 | round) / 10 | tostring)
      else ((. * 100 | round) / 100 | tostring)
      end;
    "model: \(.model)",
    "elapsed: \(.elapsed_seconds | num)s",
    "generated_tok_s: \(.generated_tok_s | num)",
    "total_tok_s: \(.total_tok_s | num)",
    "server_generated_tok_s: \(.server_generated_tok_s | num)",
    "server_prompt_tok_s: \(.server_prompt_tok_s | num)",
    "prompt_tokens: \(.prompt_tokens // "-")",
    "completion_tokens: \(.completion_tokens // "-")",
    "total_tokens: \(.total_tokens // "-")",
    "response_chars: \(.response_chars)",
    "response_preview: \(.response_preview)"
  '
}

cmd_optimize() {
  require_cmd bun
  ensure_registry
  local id=""
  if [[ $# -gt 0 && "$1" != --* ]]; then
    id="$(model_id_or_select "optimize" 0 "$1" "chat")"
    shift
  else
    id="$(model_id_or_select "optimize" 0 "" "chat")"
  fi
  require_startable_model "$id"
  log "clearing current llama runtime before optimization"
  clear_runtime
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local args=(--model-id "$id" --registry "$MODELS_JSON" --llm-bin "$script_dir/llm")
  [[ "$JSON_OUTPUT" -eq 1 ]] && args+=(--json)
  "$script_dir/llm-optimize" "${args[@]}" "$@"
}

main() {
  local id
  if [[ "${1:-}" == "--json" ]]; then
    JSON_OUTPUT=1
    shift
  fi
  case "${1:-help}" in
    help|--help|-h) usage ;;
    doctor) shift; cmd_doctor "$@" ;;
    search) shift; cmd_search "$@" ;;
    info) shift; cmd_info "$@" ;;
    pull) shift; cmd_pull "$@" ;;
    cache) shift; cmd_cache "$@" ;;
    ls) shift; cmd_ls "$@" ;;
    add) shift; cmd_add "$@" ;;
    set) shift; cmd_set "$@" ;;
    edit) shift; cmd_edit "$@" ;;
    enable) shift; id="$(model_id_or_select "enable" 1 "${1:-}")"; set_enabled true "$id"; echo "enabled: $id" ;;
    disable) shift; id="$(model_id_or_select "disable" 1 "${1:-}")"; set_enabled false "$id"; echo "disabled: $id" ;;
    reload) shift; reload_swap "$@" ;;
    start) shift; cmd_start "$@" ;;
    stop) shift; cmd_stop "$@" ;;
    restart) shift; id="$(model_id_or_select "restart" 0 "${1:-}" "chat")"; require_startable_model "$id"; log "restarting: $id"; cmd_stop "$id"; cmd_start "$id" ;;
    clear) shift; cmd_clear "$@" ;;
    ps) shift; cmd_ps "$@" ;;
    served) shift; cmd_served "$@" ;;
    status) shift; cmd_status "$@" ;;
    logs) shift; cmd_logs "$@" ;;
    test) shift; cmd_test "$@" ;;
    chat) shift; cmd_chat "$@" ;;
    bench) shift; cmd_bench "$@" ;;
    optimize) shift; cmd_optimize "$@" ;;
    rm) shift; cmd_rm "$@" ;;
    *) die "unknown command: $1" ;;
  esac
}

main "$@"
