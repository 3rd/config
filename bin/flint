#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

#/ Usage: flint [target]
#/ Description: Format and lint code
#/ Examples:
#/   flint          # format and lint current directory
#/   flint ./src    # format and lint specific target
#/ Options:
#/   --help: Display this help message
usage() {
  grep '^#/' "$0" | cut -c4-
  exit 0
}
expr "$*" : ".*--help" >/dev/null && usage

DONE=0

# go projects
if [ -f "go.mod" ]; then
  TARGET="${1:-./...}"
  # TODO: format "$TARGET"
  golangci-lint run --enable-all --exclude-use-default -e "ALL_CAPS" -e "cuddled" -e "SA9004" -e "a blank import should" "$TARGET"
  exit
fi

# js/ts projects
if [ -f "package.json" ]; then
  TARGET="${1:-.}"
  if [ -d "$TARGET/src" ]; then
    TARGET="$TARGET/src"
  fi

  echo "Formatting $TARGET"
  prettier -w "$TARGET" --config ~/.config/nvim/linters/prettier.json

  echo "Linting $TARGET"
  ESLINT_USE_FLAT_CONFIG=false ~/brain/core/linter/eslint/node_modules/eslint/bin/eslint.js -c ~/.config/nvim/linters/eslint/dist/main.js --no-eslintrc "$TARGET" --fix --cache

  DONE=1
fi

if [ -f "tsconfig.json" ]; then
  echo "Checking types..."
  npx tsc --noEmit
  DONE=1
fi

if [ "$DONE" -eq 0 ]; then
  echo "FATAL: Unknown project type."
  exit 1
fi
